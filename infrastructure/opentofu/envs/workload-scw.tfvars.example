# ==============================================================================
# Workload Cluster — Scaleway (spoke)
# Client applications cluster. Managed by the management cluster via ArgoCD hub.
# ==============================================================================

cluster_name       = "openaether-scw"
environment        = "prod"
cluster_role       = "workload"
talos_version      = "v1.12.6"
kubernetes_version = "v1.35.3"
talos_bootstrap    = false # Set to true for Phase 2

node_distribution = {
  scaleway = {
    control_planes = 3
    workers        = 3
    region         = "fr-par"
    zone           = "fr-par-1"
    instance_type  = "DEV1-M"
    image_name     = "talos-scaleway-amd64-v1.12.6"
    zones          = ["fr-par-1", "fr-par-2", "fr-par-3"]
  }
}

admin_ip = ["YOUR_IP/32"]

bastion_ssh_keys = {
  scaleway = "ssh-ed25519 AAAA... user@host"
}

git_repo_url     = "https://github.com/dis-bzh/OpenAether.git"
argocd_namespace = "management-gitops"

backup_s3_endpoint = "https://s3.fr-par.scw.cloud"
backup_s3_region   = "fr-par"
backup_s3_bucket   = "s3-openaether-tfstate-workload-scw"
