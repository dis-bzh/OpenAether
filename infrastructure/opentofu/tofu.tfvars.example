cluster_name       = "openaether"
environment        = "prod"
talos_version      = "v1.12.6"
kubernetes_version = "v1.35.3"
talos_bootstrap    = false  # Default to false for Phase 1. Use -var talos_bootstrap=true in Phase 2 via TF CLI options

# Node Distribution (Scaleway-first)
node_distribution = {
  scaleway = {
    control_planes = 3
    workers        = 2
    region         = "fr-par"
    zone           = "fr-par-2"
    instance_type  = "DEV1-M"
    image_name     = "talos-scaleway-amd64-v1.12.6"
    zones          = ["fr-par-1", "fr-par-2", "fr-par-1"] # HA across 2 AZs
  }
}

# Security — Allowed admin IPs for SSH bastion and K8s API LB ACL
admin_ip = ["YOUR_IP/32"]

bastion_ssh_keys = {
  scaleway = "ssh-ed25519 AAAA... user@host"
}

# GitOps — ArgoCD root application source
git_repo_url     = "https://github.com/dis-bzh/OpenAether.git"
argocd_namespace = "management-gitops"

# S3 Backup (Scaleway Object Storage or any S3-compatible)
backup_s3_endpoint = "https://s3.fr-par.scw.cloud"
backup_s3_region   = "fr-par"
backup_s3_bucket   = "s3-openaether-tfstate-prod"

# State encryption passphrase (32+ chars)
# Set via: export TF_VAR_encryption_passphrase="..."
