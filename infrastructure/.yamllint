extends: default

# Vendor/generated files — downloaded manifests we don't control.
ignore: |
  **/external-secrets/install.yaml
  **/traefik/standard-install.yaml
  **/linkerd/linkerd-crds.yaml
  **/linkerd/linkerd-control-plane.yaml
  **/bootstrap-manifests/argocd-install.yaml
  **/bootstrap-manifests/cilium.yaml

rules:
  document-start: disable
  line-length:
    max: 120
    allow-non-breakable-words: true
  comments-indentation: disable
  # Kubernetes manifests use both indented and non-indented block sequences.
  # 'whatever' accepts both styles to avoid rewriting upstream manifest examples.
  indentation:
    spaces: 2
    indent-sequences: whatever
    check-multi-line-strings: false
